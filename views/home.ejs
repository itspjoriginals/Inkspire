<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('./partials/head') %>
  <title>TechThreads — Stories for Technologists</title>
</head>
<body>

  <%- include('./partials/navbar') %>

  <!-- Hero Banner -->
  <div style="background: var(--ink); color: var(--cream); padding: 3.5rem 0; position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background: radial-gradient(ellipse 50% 100% at 15% 50%, rgba(201,151,74,0.18) 0%, transparent 60%);"></div>
    <div style="position:absolute; right:-2rem; top:50%; transform:translateY(-50%); font-family:'Playfair Display',serif; font-size:14rem; font-weight:900; font-style:italic; color:rgba(255,255,255,0.03); line-height:1; pointer-events:none; user-select:none;">TT</div>
    <div class="container" style="position:relative;">
      <span class="section-eyebrow" style="color: var(--gold-light);">Welcome to TechThreads</span>
      <h1 style="font-family:'Playfair Display',serif; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight:900; font-style:italic; color:var(--cream); max-width:700px; line-height:1.1; margin:0.5rem 0 1rem;">
        Ideas Worth Reading.<br>Voices Worth Hearing.
      </h1>
      <p style="font-size:1rem; color:rgba(250,247,242,0.65); max-width:480px; font-weight:300; margin:0;">
        Long-form tech writing from engineers, founders, and thinkers shaping the digital world.
      </p>
    </div>
  </div>

  <%- include('./partials/blogs') %>

  <footer class="page-footer">
    <div class="container">
      <span>© <%= new Date().getFullYear() %> TechThreads &nbsp;·&nbsp; Built for curious minds</span>
    </div>
  </footer>

  <%- include('./partials/scripts') %>
</body>
</html>
