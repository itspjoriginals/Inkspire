<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
  /* ── Design Tokens ─────────────────────────────────────── */
  :root {
    --ink:        #0f0e0c;
    --ink-soft:   #3a3530;
    --ink-muted:  #7a7068;
    --cream:      #faf7f2;
    --cream-dark: #f0ebe1;
    --gold:       #c9974a;
    --gold-light: #e8c484;
    --red-accent: #c0392b;
    --white:      #ffffff;
    --border:     #e2dbd0;
    --shadow-sm:  0 2px 8px rgba(15,14,12,0.06);
    --shadow-md:  0 8px 32px rgba(15,14,12,0.10);
    --shadow-lg:  0 20px 60px rgba(15,14,12,0.14);
    --radius:     4px;
    --transition: 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Base ───────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.65;
    background-color: var(--cream);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  /* ── Scrollbar ──────────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--cream-dark); }
  ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

  /* ── Selection ──────────────────────────────────────────── */
  ::selection { background: var(--gold-light); color: var(--ink); }

  /* ── Typography ─────────────────────────────────────────── */
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', Georgia, serif;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition);
  }

  /* ── Navbar ─────────────────────────────────────────────── */
  .navbar {
    background: var(--white) !important;
    border-bottom: 1px solid var(--border);
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: var(--shadow-sm);
  }

  .navbar-inner {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    width: 100%;
    height: 64px;
  }

  .navbar-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1.55rem;
    font-weight: 900;
    font-style: italic;
    color: var(--ink) !important;
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    padding: 0 1.5rem 0 0;
    border-right: 1px solid var(--border);
    transition: color var(--transition);
    position: relative;
  }

  .navbar-brand::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }

  .navbar-brand:hover::after { transform: scaleX(1); }
  .navbar-brand:hover { color: var(--gold) !important; }

  .navbar-tagline {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    padding-left: 1.5rem;
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ── Buttons ────────────────────────────────────────────── */
  .btn {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius);
    padding: 0.5rem 1.25rem;
    transition: all var(--transition);
    border: 1.5px solid transparent;
    cursor: pointer;
  }

  .btn-primary, .btn-dark {
    background: var(--ink) !important;
    border-color: var(--ink) !important;
    color: var(--cream) !important;
  }

  .btn-primary:hover, .btn-dark:hover {
    background: var(--gold) !important;
    border-color: var(--gold) !important;
    color: var(--ink) !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(201,151,74,0.35);
  }

  .btn-outline-dark {
    background: transparent !important;
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  .btn-outline-dark:hover {
    background: var(--ink) !important;
    color: var(--cream) !important;
    transform: translateY(-1px);
  }

  .btn-outline-secondary {
    background: transparent;
    border-color: var(--border) !important;
    color: var(--ink-soft) !important;
  }

  .btn-outline-secondary:hover {
    background: var(--cream-dark) !important;
    border-color: var(--ink-muted) !important;
    color: var(--ink) !important;
  }

  .btn-write {
    background: var(--gold) !important;
    border-color: var(--gold) !important;
    color: var(--ink) !important;
    font-weight: 600;
  }

  .btn-write:hover {
    background: var(--ink) !important;
    border-color: var(--ink) !important;
    color: var(--cream) !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(15,14,12,0.25);
  }

  /* ── Dropdown ───────────────────────────────────────────── */
  .dropdown-menu {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 0.4rem 0;
    background: var(--white);
    min-width: 160px;
    animation: dropIn 0.2s ease;
  }

  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dropdown-item {
    font-size: 0.85rem;
    padding: 0.55rem 1.1rem;
    color: var(--ink-soft);
    transition: all 0.18s ease;
    font-weight: 400;
  }

  .dropdown-item:hover {
    background: var(--cream-dark);
    color: var(--ink);
    padding-left: 1.4rem;
  }

  .avatar-ring {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 2px solid var(--border);
    object-fit: cover;
    cursor: pointer;
    transition: border-color var(--transition), transform var(--transition);
  }

  .avatar-ring:hover {
    border-color: var(--gold);
    transform: scale(1.07);
  }

  /* ── Hero / Section Headers ─────────────────────────────── */
  .section-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
    display: block;
  }

  /* ── Blog Cards ─────────────────────────────────────────── */
  .blog-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all var(--transition);
    overflow: hidden;
    position: relative;
  }

  .blog-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--gold);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform var(--transition);
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .blog-card:hover::before { transform: scaleY(1); }

  .blog-card-inner {
    padding: 1.75rem 2rem;
  }

  .blog-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.22rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--ink);
    transition: color var(--transition);
  }

  .blog-card-title:hover { color: var(--gold); }

  .blog-card-excerpt {
    color: var(--ink-muted);
    font-size: 0.88rem;
    line-height: 1.7;
    margin: 0.6rem 0 1rem;
    font-weight: 300;
  }

  .blog-card-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .blog-card-meta .dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--gold);
    display: inline-block;
  }

  .blog-card-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card-img-wrap {
    overflow: hidden;
    border-radius: 6px;
  }

  .blog-card:hover .blog-card-img { transform: scale(1.04); }

  /* ── Forms ──────────────────────────────────────────────── */
  .form-label {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.4rem;
  }

  .form-control, .form-select {
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    padding: 0.65rem 0.9rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .form-control:focus, .form-select:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,151,74,0.15);
    outline: none;
    background: var(--white);
  }

  .form-control::placeholder { color: var(--ink-muted); font-weight: 300; }

  textarea.form-control { resize: vertical; min-height: 200px; }

  /* ── Auth Pages ─────────────────────────────────────────── */
  .auth-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem 3rem;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
  }

  .auth-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
  }

  .auth-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 900;
    font-style: italic;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .auth-subtitle {
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin-bottom: 2rem;
    font-weight: 300;
  }

  /* ── Blog Page (single) ─────────────────────────────────── */
  .blog-page-header {
    background: var(--ink);
    color: var(--cream);
    padding: 4rem 0 3rem;
    position: relative;
    overflow: hidden;
  }

  .blog-page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(201,151,74,0.12) 0%, transparent 70%);
  }

  .blog-page-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    color: var(--cream);
    line-height: 1.15;
    position: relative;
  }

  .blog-page-body {
    font-size: 1.08rem;
    line-height: 1.85;
    color: var(--ink-soft);
    font-weight: 300;
  }

  .blog-page-body p { margin-bottom: 1.4em; }

  /* ── Divider ────────────────────────────────────────────── */
  .ornament-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2.5rem 0;
  }

  .ornament-divider::before,
  .ornament-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .ornament-divider span {
    color: var(--gold);
    font-size: 1.1rem;
  }

  /* ── Alerts ─────────────────────────────────────────────── */
  .alert-success {
    background: #f0faf5;
    border: 1px solid #a3d9b8;
    color: #1d6a40;
    border-radius: var(--radius);
    font-size: 0.875rem;
  }

  .alert-danger {
    background: #fef2f2;
    border: 1px solid #f8b4b4;
    color: #991b1b;
    border-radius: var(--radius);
    font-size: 0.875rem;
  }

  /* ── Page Transitions ───────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fade-up {
    animation: fadeUp 0.55s cubic-bezier(0.4,0,0.2,1) both;
  }

  .fade-up-delay-1 { animation-delay: 0.1s; }
  .fade-up-delay-2 { animation-delay: 0.2s; }
  .fade-up-delay-3 { animation-delay: 0.3s; }

  /* ── Footer strip ───────────────────────────────────────── */
  .page-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 5rem;
    text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 767px) {
    .navbar-tagline { display: none; }
    .auth-card { padding: 2rem 1.5rem; }
    .blog-card-inner { padding: 1.25rem 1.25rem; }
  }
</style>
