<div class="container mt-4">
  <h1 class="mb-4">All Blogs</h1>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% blogs.forEach(blog => { %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <% if (blog.coverImageURL) { %>
            <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %>" style="height: 200px; object-fit: fit;">
          <% } else { %>
            <div class="card-img-top bg-light d-flex justify-content-center align-items-center" style="height: 200px;">
              <span class="text-muted">No image</span>
            </div>
          <% } %>
          <div class="card-body">
            <h5 class="card-title"><%= blog.title %></h5>
            <p class="card-text">
              <%= blog.body.substring(0, 150) %>
              <% if (blog.body.length > 150) { %>...<% } %>
            </p>
            <% if (locals.user) { %>
              <a href="/blog/<%= blog._id %>" class="btn btn-primary btn-sm">Read More</a>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>