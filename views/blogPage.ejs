<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('./partials/head') %>
  <title><%= blog.title %> — TechThreads</title>
</head>
<body>

  <%- include('./partials/navbar') %>

  <!-- Dark Hero Header -->
  <div class="blog-page-header">
    <div class="container" style="max-width: 800px; position: relative;">

      <div class="blog-card-meta mb-3" style="color: rgba(250,247,242,0.5);">
        <span class="dot"></span>
        <span><%= blog.createdAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
        <span class="dot"></span>
        <span>By <%= blog.createdBy.fullName %></span>
      </div>

      <h1 class="blog-page-title fade-up"><%= blog.title %></h1>

      <!-- Author chip -->
      <div class="d-flex align-items-center mt-4 gap-3">
        <img
          src="<%= blog.createdBy.profileImageURL %>"
          width="44" height="44"
          class="rounded-circle"
          style="border: 2px solid rgba(201,151,74,0.5); object-fit:cover;"
          alt="<%= blog.createdBy.fullName %>"
        >
        <div>
          <div style="font-size:0.88rem; font-weight:500; color: var(--cream);"><%= blog.createdBy.fullName %></div>
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; letter-spacing:0.08em; text-transform:uppercase; color:rgba(250,247,242,0.45);">Author</div>
        </div>
      </div>

    </div>
  </div>

  <!-- Article Body -->
  <div class="container pb-5" style="max-width: 800px;">

    <!-- Cover Image -->
    <% if (blog.coverImageURL) { %>
      <div class="fade-up" style="margin-top:-2rem; margin-bottom:2.5rem; border-radius:10px; overflow:hidden; box-shadow:var(--shadow-lg);">
        <img src="<%= blog.coverImageURL %>" style="width:100%; max-height:460px; object-fit:cover; display:block;" alt="<%= blog.title %>">
      </div>
    <% } else { %>
      <div style="margin-top: 3rem;"></div>
    <% } %>

    <div class="ornament-divider fade-up"><span>✦</span></div>

    <!-- Body text -->
    <div class="blog-page-body fade-up">
      <%- blog.body %>
    </div>

    <div class="ornament-divider"><span>✦</span></div>

    <!-- Back link -->
    <div class="fade-up">
      <a href="/" style="display:inline-flex; align-items:center; gap:0.4rem; font-size:0.8rem; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-muted); transition:color 0.2s ease;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back to all stories
      </a>
    </div>

  </div>

  <footer class="page-footer">
    <div class="container">
      <span>© <%= new Date().getFullYear() %> TechThreads &nbsp;·&nbsp; Built for curious minds</span>
    </div>
  </footer>

  <%- include('./partials/scripts') %>
</body>
</html>
