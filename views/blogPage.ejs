<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('./partials/head') %>
  <title><%= blog?.title || "Blog" %> - Blog</title>
</head>
<body>
  <%- include('./partials/navbar') %>

<div class="container mt-5">
    <% if (locals.error) { %>
      <div class="alert alert-danger">
        <%= locals.error %>
      </div>
      <a href="/" class="btn btn-outline-secondary">Go to Home</a>
    <% } else if (blog) { %>

      <!-- Cover image (with fallback) -->
      <% if (blog.coverImageURL && blog.coverImageURL.trim() !== "") { %>
        <div class="mb-4">
          <img
            src="<%= blog.coverImageURL %>"
            alt="<%= blog.title %>"
            class="img-fluid rounded shadow-sm"
            style="max-height: 400px; object-fit: cover; width: 100%;"
          >
        </div>
      <% } else { %>
        <div class="mb-4 bg-light d-flex justify-content-center align-items-center rounded" style="height: 250px; border: 1px solid #ddd;">
          <span class="text-muted">No image</span>
        </div>
      <% } %>

      <!-- Title -->
      <h1 class="mb-3"><%= blog.title %></h1>

      <!-- Body (preserves spacing/line breaks) -->
      <div class="mb-4">
        <pre >
<%= blog.body %>
        </pre>
      </div>

      <!-- Metadata -->
      <div class="text-muted small mb-4">
        <span>Published on <%= blog.createdAt.toLocaleDateString() %></span>
      </div>

      <div class="mb-4">
  <img
    src="<%= blog.createdBy.profileImageURL %>"
    alt="Author"
    class="rounded-circle me-2"
    style="width: 40px; height: 40px; object-fit: cover;"
  >
  <%= blog.createdBy.fullName %>
</div>

      <!-- Back button -->
      <a href="/" class="btn btn-outline-primary">← Back to Blogs</a>

